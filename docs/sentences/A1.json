    {"de": "Eine Minute hat sechzig Sekunden.", "ru": "В минуте шестьдесят секунд."},
    {"de": "Der Film dauert zwei Stunden.", "ru": "Фильм длится два часа."},
    {"de": "Ein Tag hat vierundzwanzig Stunden.", "ru": "В сутках двадцать четыре часа."},
    {"de": "Eine Woche hat sieben Tage.", "ru": "В неделе семь дней."},
    {"de": "Ein Monat hat vier Wochen.", "ru": "В месяце четыре недели."},
    {"de": "Ein Jahr hat zwölf Monate.", "ru": "В году двенадцать месяцев."},
    {"de": "Am Montag beginnt die Woche.", "ru": "В понедельник начинается неделя."},
    {"de": "Am Wochenende habe ich frei.", "ru": "На выходных я свободен."},
    {"de": "Heute Morgen war ich im Park.", "ru": "Сегодня утром я был в парке."},
    {"de": "Guten Morgen, Herr Müller!", "ru": "Доброе утро, господин Мюллер!"},
    {"de": "Am Vormittag trinke ich Kaffee.", "ru": "В первой половине дня я пью кофе."},
    {"de": "Mittags esse ich warm.", "ru": "В полдень я ем горячее."},
    {"de": "Am Nachmittag lese ich ein Buch.", "ru": "Во второй половине дня я читаю книгу."},
    {"de": "Guten Abend, meine Damen!", "ru": "Добрый вечер, дамы!"},
    {"de": "Gute Nacht und träum süß!", "ru": "Спокойной ночи и сладких снов!"},
    {"de": "Am Morgen ist es kühl.", "ru": "Утром прохладно."},
    {"de": "Am Abend ist es dunkel.", "ru": "Вечером темно."},
    {"de": "In der Nacht schlafen die Menschen.", "ru": "Ночью люди спят."},
    {"de": "Heute ist der erste April.", "ru": "Сегодня первое апреля."},
    {"de": "Im Februar ist es kalt.", "ru": "В феврале холодно."},
    {"de": "Im Sommer fahre ich ans Meer.", "ru": "Летом я еду к морю."},
    {"de": "Der Frühling ist bunt.", "ru": "Весна разноцветная."},
    {"de": "Der Herbst ist neblig.", "ru": "Осень туманная."},
    {"de": "Der Winter ist weiß.", "ru": "Зима белая."},
    {"de": "Das kostet einen Euro dreißig.", "ru": "Это стоит один евро тридцать."},
    {"de": "Ein Meter sind hundert Zentimeter.", "ru": "В одном метре сто сантиметров."},
    {"de": "Zwischen Köln und Bonn sind dreißig Kilometer.", "ru": "Между Кёльном и Бонном тридцать километров."},
    {"de": "Die Wohnung ist achtzig Quadratmeter groß.", "ru": "Квартира имеет площадь восемьдесят квадратных метров."},
    {"de": "Es ist ein Grad über Null.", "ru": "Один градус выше нуля."},
    {"de": "Zehn Prozent sind ein Zehntel.", "ru": "Десять процентов — это одна десятая."},
    {"de": "Ein Liter Milch, bitte!", "ru": "Один литр молока, пожалуйста!"},
    {"de": "Ein Kilo Äpfel kostet zwei Euro.", "ru": "Килограмм яблок стоит два евро."},
    {"de": "Ein Pfund ist fünfhundert Gramm.", "ru": "Один фунт — это пятьсот граммов."},
    {"de": "Deutschland liegt in Europa.", "ru": "Германия находится в Европе."},
    {"de": "Er ist Deutscher.", "ru": "Он немец."},
    {"de": "Sie ist Deutsche.", "ru": "Она немка."},
    {"de": "Die deutsche Sprache ist schwer.", "ru": "Немецкий язык трудный."},
    {"de": "Die Europäer sind viele Kulturen.", "ru": "Европейцы — это много культур."},
    {"de": "Das ist eine schwarze Katze.", "ru": "Это чёрная кошка."},
    {"de": "Der Himmel ist blau.", "ru": "Небо синее."},
    {"de": "Das Gras ist grün.", "ru": "Трава зелёная."},
    {"de": "Die Blume ist rot.", "ru": "Цветок красный."},
    {"de": "Die Sonne ist gelb.", "ru": "Солнце жёлтое."},
    {"de": "Der Schnee ist weiß.", "ru": "Снег белый."},
    {"de": "Der Hund ist braun.", "ru": "Собака коричневая."},
    {"de": "Die Wand ist grau.", "ru": "Стена серая."},
    {"de": "Der Norden ist kalt.", "ru": "Север холодный."},
    {"de": "Der Süden ist warm.", "ru": "Юг тёплый."},
    {"de": "Der Westen ist regnerisch.", "ru": "Запад дождливый."},
    {"de": "Die Sonne geht im Osten auf.", "ru": "Солнце встаёт на востоке."},
    {"de": "Das ist mein Buch.", "ru": "Это моя книга."},
    {"de": "Ist das dein Stift?", "ru": "Это твоя ручка?"},
    {"de": "Das ist unser Haus.", "ru": "Это наш дом."},
    {"de": "Das ist eure Entscheidung.", "ru": "Это ваше решение."},
    {"de": "Das ist Ihr Platz, Frau Schmidt.", "ru": "Это Ваше место, фрау Шмидт."},
    {"de": "Dieser Film ist gut.", "ru": "Этот фильм хороший."},
    {"de": "Welchen Tag haben wir heute?", "ru": "Какой сегодня день?"},
    {"de": "Jeder Mensch ist anders.", "ru": "Каждый человек разный."},
    {"de": "Alle Kinder sind da.", "ru": "Все дети здесь."},
    {"de": "Beide Eltern arbeiten.", "ru": "Оба родителя работают."},
    {"de": "Der andere Weg ist kürzer.", "ru": "Другой путь короче."},
    {"de": "Das ist das, was ich meine.", "ru": "Это то, что я имею в виду."},
    {"de": "Wer ist das?", "ru": "Кто это?"},
    {"de": "Was ist das?", "ru": "Что это?"},
    {"de": "Was machst du da?", "ru": "Что ты там делаешь?"},
    {"de": "Man darf hier nicht rauchen.", "ru": "Здесь нельзя курить."},
    {"de": "Hat jemand meinen Schlüssel gesehen?", "ru": "Кто-нибудь видел мой ключ?"},
    {"de": "Niemand ist perfekt.", "ru": "Никто не совершенен."},
    {"de": "Ich habe etwas vergessen.", "ru": "Я что-то забыл."},
    {"de": "Er weiß nichts davon.", "ru": "Он ничего об этом не знает."},
    {"de": "Das ist nicht gut.", "ru": "Это нехорошо."},
    {"de": "Es ist sehr warm heute.", "ru": "Сегодня очень тепло."},
    {"de": "Er ist auch da.", "ru": "Он тоже там."},
    {"de": "Ich habe nur fünf Euro.", "ru": "У меня только пять евро."},
    {"de": "Ich bin noch nicht fertig.", "ru": "Я ещё не готов."},
    {"de": "Das habe ich schon gesehen.", "ru": "Я это уже видел."},
    {"de": "Komm bald wieder!", "ru": "Приходи скорее снова!"},
    {"de": "Es ist schon spät.", "ru": "Уже поздно."},
    {"de": "Ich stehe früh auf.", "ru": "Я рано встаю."},
    {"de": "Komm sofort her!", "ru": "Иди сейчас же сюда!"},
    {"de": "Da hinten ist ein Park.", "ru": "Там позади парк."},
    {"de": "Hier ist es laut.", "ru": "Здесь шумно."},
    {"de": "Dort drüben ist meine Schule.", "ru": "Вон там моя школа."},
    {"de": "Geh nach links!", "ru": "Иди налево!"},
    {"de": "Fahr nach rechts!", "ru": "Поворачивай направо!"},
    {"de": "Geh geradeaus!", "ru": "Иди прямо!"},
    {"de": "Setz dich nach vorne!", "ru": "Садись вперёд!"},
    {"de": "Stell dich nach hinten!", "ru": "Встань сзади!"},
    {"de": "Der Schlüssel liegt oben.", "ru": "Ключ лежит наверху."},
    {"de": "Die Zeitung ist unten.", "ru": "Газета внизу."},
    {"de": "Es ist warm drinnen.", "ru": "Внутри тепло."},
    {"de": "Es ist kalt draußen.", "ru": "На улице холодно."},
    {"de": "Setz dich neben mich!", "ru": "Садись рядом со мной!"},
    {"de": "Die Bank ist gegenüber.", "ru": "Банк напротив."},
    {"de": "Das Auto ist überall.", "ru": "Машина везде."},
    {"de": "Ich und du, wir sind Freunde.", "ru": "Я и ты, мы друзья."},
    {"de": "Du oder ich?", "ru": "Ты или я?"},
    {"de": "Er ist klein, aber stark.", "ru": "Он маленький, но сильный."},
    {"de": "Er kommt nicht, denn er ist krank.", "ru": "Он не приходит, потому что болен."},
    {"de": "Ich denke, dass du recht hast.", "ru": "Я думаю, что ты прав."},
    {"de": "Ich bleibe zu Hause, weil es regnet.", "ru": "Я остаюсь дома, потому что идёт дождь."},
    {"de": "Wenn du Zeit hast, komm vorbei.", "ru": "Если у тебя есть время, заходи."},
    {"de": "Als ich klein war, wohnte ich in Berlin.", "ru": "Когда я был маленьким, я жил в Берлине."},
    {"de": "Wasch dir die Hände, bevor du isst.", "ru": "Помой руки, прежде чем есть."},
    {"de": "Nachdem er gegessen hatte, ging er schlafen.", "ru": "После того как он поел, он пошёл спать."},
    {"de": "Während ich arbeite, höre ich Musik.", "ru": "Пока я работаю, я слушаю музыку."},
    {"de": "Er spricht laut, damit alle ihn hören.", "ru": "Он говорит громко, чтобы все его слышали."},
    {"de": "Ab morgen muss ich arbeiten.", "ru": "С завтрашнего дня я должен работать."},
    {"de": "Das Bild hängt an der Wand.", "ru": "Картина висит на стене."},
    {"de": "Er kommt aus Berlin.", "ru": "Он из Берлина."},
    {"de": "Sie wohnt bei ihren Eltern.", "ru": "Она живёт у своих родителей."},
    {"de": "Ich arbeite bis fünf Uhr.", "ru": "Я работаю до пяти часов."},
    {"de": "Er geht durch den Park.", "ru": "Он идёт через парк."},
    {"de": "Das Geschenk ist für dich.", "ru": "Подарок для тебя."},
    {"de": "Ich bin gegen diesen Plan.", "ru": "Я против этого плана."},
    {"de": "Er arbeitet in einer Firma.", "ru": "Он работает в фирме."},
    {"de": "Ich fahre mit dem Bus.", "ru": "Я еду на автобусе."},
    {"de": "Nach dem Essen gehen wir spazieren.", "ru": "После еды мы идём гулять."},
    {"de": "Er geht ohne Mantel aus.", "ru": "Он выходит без пальто."},
    {"de": "Ich wohne seit drei Jahren hier.", "ru": "Я живу здесь с трёх лет."},
    {"de": "Wir treffen uns um sechs Uhr.", "ru": "Мы встречаемся в шесть часов."},
    {"de": "Die Katze sitzt unter dem Tisch.", "ru": "Кошка сидит под столом."},
    {"de": "Das Geschenk ist von meiner Mutter.", "ru": "Подарок от моей мамы."},
    {"de": "Ich habe Angst vor Hunden.", "ru": "Я боюсь собак."},
    {"de": "Er geht zu seiner Oma.", "ru": "Он идёт к своей бабушке."},
    {"de": "Das Haus steht zwischen zwei Bäumen.", "ru": "Дом стоит между двумя деревьями."},
    {"de": "Ich habe keine Zeit.", "ru": "У меня нет времени."},
    {"de": "Sie haben ein neues Auto.", "ru": "У них новая машина."},
    {"de": "Wir werden morgen kommen.", "ru": "Мы придём завтра."},
    {"de": "Ich kann Deutsch sprechen.", "ru": "Я умею говорить по-немецки."},
    {"de": "Er will einen Hund haben.", "ru": "Он хочет иметь собаку."},
    {"de": "Du musst pünktlich sein.", "ru": "Ты должен быть вовремя."},
    {"de": "Sie darf heute länger aufbleiben.", "ru": "Ей можно сегодня лечь спать позже."},
    {"de": "Ihr sollt leise sein.", "ru": "Вы должны быть тихими."},
    {"de": "Ich mag Pizza.", "ru": "Я люблю пиццу."},
    {"de": "Möchtest du einen Tee?", "ru": "Хочешь чай?"},
    {"de": "Wir möchten heute ins Kino gehen.", "ru": "Мы хотели бы сегодня пойти в кино."},
    {"de": "Wie heißt du?", "ru": "Как тебя зовут?"},
    {"de": "Ich heiße Thomas.", "ru": "Меня зовут Томас."},
    {"de": "Sie wohnt in Hamburg.", "ru": "Она живёт в Гамбурге."},
    {"de": "Wir leben in Deutschland.", "ru": "Мы живём в Германии."},
    {"de": "Er arbeitet als Arzt.", "ru": "Он работает врачом."},
    {"de": "Ich lerne Deutsch.", "ru": "Я учу немецкий."},
    {"de": "Sie studiert Medizin.", "ru": "Она учится на врача."},
    {"de": "Er spricht zu schnell.", "ru": "Он говорит слишком быстро."},
    {"de": "Sie sagt immer die Wahrheit.", "ru": "Она всегда говорит правду."},
    {"de": "Ich frage den Lehrer.", "ru": "Я спрашиваю учителя."},
    {"de": "Er antwortet nicht.", "ru": "Он не отвечает."},
    {"de": "Erzähl mir eine Geschichte.", "ru": "Расскажи мне историю."},
    {"de": "Kannst du das erklären?", "ru": "Ты можешь это объяснить?"},
    {"de": "Wiederhole das bitte.", "ru": "Повтори это, пожалуйста."},
    {"de": "Ich verstehe die Frage nicht.", "ru": "Я не понимаю вопрос."},
    {"de": "Hörst du die Musik?", "ru": "Ты слышишь музыку?"},
    {"de": "Ich sehe einen Vogel.", "ru": "Я вижу птицу."},
    {"de": "Er liest ein Buch.", "ru": "Он читает книгу."},
    {"de": "Sie schreibt einen Brief.", "ru": "Она пишет письмо."},
    {"de": "Ich zeichne ein Haus.", "ru": "Я рисую дом."},
    {"de": "Er malt ein Bild.", "ru": "Он рисует картину."},
    {"de": "Was machst du da?", "ru": "Что ты там делаешь?"},
    {"de": "Kannst du mir helfen?", "ru": "Ты можешь мне помочь?"},
    {"de": "Er sucht seinen Schlüssel.", "ru": "Он ищет свой ключ."},
    {"de": "Ich finde den Fehler nicht.", "ru": "Я не нахожу ошибку."},
    {"de": "Sie kauft ein neues Kleid.", "ru": "Она покупает новое платье."},
    {"de": "Er verkauft sein altes Auto.", "ru": "Он продаёт свою старую машину."},
    {"de": "Wie viel kostet das Hemd?", "ru": "Сколько стоит рубашка?"},
    {"de": "Ich bezahle bar.", "ru": "Я плачу наличными."},
    {"de": "Er zahlt mit Karte.", "ru": "Он платит картой."},
    {"de": "Nimm den Stift!", "ru": "Возьми ручку!"},
    {"de": "Gib mir bitte das Buch!", "ru": "Дай мне, пожалуйста, книгу!"},
    {"de": "Bring mir einen Kaffee!", "ru": "Принеси мне кофе!"},
    {"de": "Hole bitte die Post!", "ru": "Забери, пожалуйста, почту!"},
    {"de": "Leg das Buch auf den Tisch!", "ru": "Положи книгу на стол!"},
    {"de": "Stell die Vase dort hin!", "ru": "Поставь вазу туда!"},
    {"de": "Öffne das Fenster!", "ru": "Открой окно!"},
    {"de": "Schließe die Tür!", "ru": "Закрой дверь!"},
    {"de": "Mach die Heizung an!", "ru": "Включи отопление!"},
    {"de": "Mach den Fernseher aus!", "ru": "Выключи телевизор!"},
    {"de": "Mach das Licht zu!", "ru": "Выключи свет!"},
    {"de": "Mach die Tür auf!", "ru": "Открой дверь!"},
    {"de": "Geh nach Hause!", "ru": "Иди домой!"},
    {"de": "Komm zu mir!", "ru": "Приходи ко мне!"},
    {"de": "Fahr langsamer!", "ru": "Едь медленнее!"},
    {"de": "Lauf nicht so schnell!", "ru": "Не беги так быстро!"},
    {"de": "Steh auf!", "ru": "Вставай!"},
    {"de": "Setz dich hin!", "ru": "Садись!"},
    {"de": "Leg dich hin!", "ru": "Ложись!"},
    {"de": "Bleib hier!", "ru": "Оставайся здесь!"},
    {"de": "Schwimm nicht zu weit!", "ru": "Не плыви слишком далеко!"},
    {"de": "Tanz mit mir!", "ru": "Потанцуй со мной!"},
    {"de": "Spiel mit uns!", "ru": "Поиграй с нами!"},
    {"de": "Schlaf gut!", "ru": "Спи хорошо!"},
    {"de": "Steh um sieben auf!", "ru": "Встань в семь!"},
    {"de": "Frühstückst du zu Hause?", "ru": "Ты завтракаешь дома?"},
    {"de": "Isst du Fleisch?", "ru": "Ты ешь мясо?"},
    {"de": "Trinkst du Milch?", "ru": "Ты пьёшь молоко?"},
    {"de": "Kochst du gerne?", "ru": "Ты любишь готовить?"},
    {"de": "Backst du einen Kuchen?", "ru": "Ты печёшь пирог?"},
    {"de": "Grillst du im Sommer?", "ru": "Ты готовишь барбекю летом?"},
    {"de": "Warte auf mich!", "ru": "Подожди меня!"},
    {"de": "Feierst du deinen Geburtstag?", "ru": "Ты празднуешь свой день рождения?"},
    {"de": "Lädst du mich ein?", "ru": "Ты приглашаешь меня?"},
    {"de": "Besuchst du deine Oma?", "ru": "Ты навещаешь свою бабушку?"},
    {"de": "Triffst du deine Freunde?", "ru": "Ты встречаешься со своими друзьями?"},
    {"de": "Beginnt der Film um acht?", "ru": "Фильм начинается в восемь?"},
    {"de": "Hörst du um zehn auf?", "ru": "Ты заканчиваешь в десять?"},
    {"de": "Bleibst du über Nacht?", "ru": "Ты остаёшься на ночь?"},
    {"de": "Passt die Jacke?", "ru": "Куртка подходит?"},
    {"de": "Gefällt dir das Kleid?", "ru": "Тебе нравится платье?"},
    {"de": "Schmeckt die Suppe?", "ru": "Суп вкусный?"},
    {"de": "Riecht die Blume gut?", "ru": "Цветок хорошо пахнет?"},
    {"de": "Wie fühlst du dich?", "ru": "Как ты себя чувствуешь?"},
    {"de": "Glaubst du mir?", "ru": "Ты веришь мне?"},
    {"de": "Was denkst du darüber?", "ru": "Что ты думаешь об этом?"},
    {"de": "Weißt du die Antwort?", "ru": "Ты знаешь ответ?"},
    {"de": "Kennst du diesen Mann?", "ru": "Ты знаешь этого мужчину?"},
    {"de": "Lernst du gerne neue Leute kennen?", "ru": "Тебе нравится знакомиться с новыми людьми?"},
    {"de": "Freust du dich auf das Wochenende?", "ru": "Ты радуешься выходным?"},
    {"de": "Ärgerst du dich über den Lärm?", "ru": "Ты злишься из-за шума?"},
    {"de": "Interessierst du dich für Politik?", "ru": "Ты интересуешься политикой?"},
    {"de": "Kümmerst du dich um deine Oma?", "ru": "Ты заботишься о своей бабушке?"},
    {"de": "Erinnerst du dich an mich?", "ru": "Ты помнишь меня?"},
    {"de": "Hast du dich in jemanden verliebt?", "ru": "Ты в кого-нибудь влюбился?"},
    {"de": "Heiratest du sie?", "ru": "Ты женишься на ней?"},
    {"de": "Setz dich zu mir!", "ru": "Садись ко мне!"},
    {"de": "Zieh dich warm an!", "ru": "Одевайся тепло!"},
    {"de": "Zieh die Schuhe aus!", "ru": "Сними обувь!"},
    {"de": "Dusche dich ab!", "ru": "Прими душ!"},
    {"de": "Wasch dir die Hände!", "ru": "Помой руки!"},
    {"de": "Beeil dich, sonst kommst du zu spät!", "ru": "Торопись, иначе опоздаешь!"},
    {"de": "Unterhaltet euch leise!", "ru": "Разговаривайте тихо!"},
    {"de": "Hast du dich verletzt?", "ru": "Ты ушибся?"},
    {"de": "Zieh dich an, wir gehen!", "ru": "Одевайся, мы идём!"},
    {"de": "Ruh dich aus, du bist müde.", "ru": "Отдохни, ты устал."},
    {"de": "Stell dich vor!", "ru": "Представься!"},
    {"de": "Treffen wir uns am Bahnhof?", "ru": "Встретимся на вокзале?"},
    {"de": "Interessierst du dich für Kunst?", "ru": "Ты интересуешься искусством?"},
    {"de": "Das ist meine Familie.", "ru": "Это моя семья."},
    {"de": "Meine Mutter kocht gern.", "ru": "Моя мама любит готовить."},
    {"de": "Mein Vater arbeitet viel.", "ru": "Мой отец много работает."},
    {"de": "Meine Eltern sind im Urlaub.", "ru": "Мои родители в отпуске."},
    {"de": "Mein Bruder ist jünger als ich.", "ru": "Мой брат младше меня."},
    {"de": "Meine Schwester ist älter.", "ru": "Моя сестра старше."},
    {"de": "Die Tochter ist klein.", "ru": "Дочь маленькая."},
    {"de": "Der Sohn spielt Fußball.", "ru": "Сын играет в футбол."},
